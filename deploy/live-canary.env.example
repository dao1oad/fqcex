PERP_PLATFORM_APP_NAME=perp-platform-live-canary
PERP_PLATFORM_ENVIRONMENT=live-canary
PERP_PLATFORM_LOG_LEVEL=INFO
PERP_PLATFORM_IMAGE_REPO=perp-platform
PERP_PLATFORM_IMAGE_TAG=latest
CONTROL_PLANE_BIND_ADDRESS=127.0.0.1
CONTROL_PLANE_PORT=8080
OPERATOR_UI_BIND_ADDRESS=127.0.0.1
OPERATOR_UI_PORT=4173
LIVE_CANARY_ENABLED=true
LIVE_CANARY_ALLOWED_VENUES=BYBIT,BINANCE,OKX
LIVE_CANARY_ALLOWED_INSTRUMENTS=BTC-USDT-PERP,ETH-USDT-PERP
LIVE_CANARY_MAX_NOTIONAL_USD=250
LIVE_CANARY_KILL_SWITCH_PATH=/srv/perp-platform/state/kill-switch.flag
BYBIT_CREDENTIALS_FILE=/srv/perp-platform/secrets/bybit.env
BINANCE_CREDENTIALS_FILE=/srv/perp-platform/secrets/binance.env
OKX_CREDENTIALS_FILE=/srv/perp-platform/secrets/okx.env
